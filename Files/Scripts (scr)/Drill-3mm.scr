Edit 'BSS138.dev';
Prefix 'Q';
Description '\
Fairchild Semiconductors BSS138 N-Channel Logic Level Enhancement Mode Field Effect Transistor\n\
<br><br>\n\
General Description:\n\
These N-Channel enhancement mode field effect transistors are produced using Fairchild''s proprietary,\n\
high cell density, DMOS technology. These products have been designed to minimize on-state resistance\n\
while provide rugged, reliable, and fast switching performance.These products are particularly suited for\n\
low voltage, low current applications such as small servo motor control, power MOSFET gate drivers, and\n\
other switching applications.\n\
<br><br>\n\
Features: \n\
0.22 A, 50 V. RDS(ON) = 3.5Ohm @ VGS = 10 V RDS(ON) = 6.0Ohm @ VGS = 4.5 V \n\
High density cell design for extremely low RDS(ON) \n\
Rugged and Reliable \n\
Compact industry standard SOT-23 surface mount package';
Value on;
Add BSS138-IGFET-3-N-CH 'A' next 0 (-2.54 0);
Package 'SOT23' '';
Technology '';
Technology '';
Attribute FARNELL '1431319' variable;
Connect  'A.D' '3'  'A.G' '1'  'A.S' '2';

Edit '22UF-25V-TANT(CASED2917).dev';
Prefix 'C';
Description 'Tantalum Capacitor , 2917.   22UF, 25V, CASE D';
Value on;
Add CAPH-1 'A' next 0 (0 0);
Package 'CAPCP7343X430N' '';
Technology '';
Technology '';
Attribute SUPPLIER 'AVX' variable;
Attribute VOLTAGERATING '25V' variable;
Attribute CAPACITANCETOLERANCE '±10%' variable;
Attribute VALUE '22UF' variable;
Attribute MPN 'T495D226K025ASE200' variable;
Connect  'A.1' '1'  'A.2' '2';

Edit 'CRS08.dev';
Prefix 'D';
Description '\
<B>DIODE</B><p>\n\
TOSHIBA Schottky Barrier Rectifier Schottky Barrier Type.';
Value off;
Add D 'G$1' next 0 (0 0);
Package '3-2A1A' '';
Technology '';
Connect  'G$1.A' 'A'  'G$1.C' 'C';

Edit 'ABM8-27.dev';
Prefix 'X';
Description '\
<b>MHz RANGE CRYSTAL UNIT</b> <p>\n\
ABRACON  ABM8-27.000MHZ-B2-T  CRYSTAL, 27MHZ, 18PF, 3.2 X 2.5MM';
Value on;
Add Q-SHIELD2 'G$1' next 0 (0 0);
Package 'ABM8' '';
Technology '';
Connect  'G$1.1' '1'  'G$1.2' '2'  'G$1.3' '3'  'G$1.4' '4';
Grid inch;
Edit ;
